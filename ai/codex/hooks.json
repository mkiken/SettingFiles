{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "~/.codex/hooks/codex-stop-notification.sh",
            "type": "command"
          },
          {
            "command": "python3 ~/.codex/hooks/codex-hook.py",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.codex/hooks/codex-hook.py",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.codex/hooks/codex-stop-notification.sh",
            "type": "command"
          },
          {
            "command": "python3 ~/.codex/hooks/codex-hook.py",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ~/.codex/hooks/codex-hook.py",
            "type": "command"
          }
        ]
      }
    ]
  }
}
