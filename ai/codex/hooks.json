{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "workmux set-window-status working >/dev/null 2>&1 || true",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "workmux set-window-status done >/dev/null 2>&1 || true",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "workmux set-window-status working >/dev/null 2>&1 || true",
            "type": "command"
          }
        ]
      }
    ]
  }
}
