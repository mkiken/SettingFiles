{
  "mcpServers": {
    "context7": {
      "command": "zsh",
      "args": ["-c", "exec \"$HOME/.config/ai-mcp/bin/context7\""]
    },
    "sequential-thinking": {
      "command": "zsh",
      "args": ["-c", "exec \"$HOME/.config/ai-mcp/bin/sequential-thinking\""]
    },
    "serena": {
      "command": "/usr/local/bin/uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ]
    },
    "gitmcp": {
      "command": "zsh",
      "args": ["-c", "exec \"$HOME/.config/ai-mcp/bin/gitmcp\" https://gitmcp.io/docs"]
    }
  }
}
