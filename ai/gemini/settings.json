{
  "_disabledMcpServers": {
    "magic": {
      "_disabledReason": "Tool names start with '21st_' which violates Gemini's function naming rules (must start with letter/underscore, not number)",
      "_geminiCompatibility": "NOT_COMPATIBLE - Tool names start with '21st_' which violates Gemini function naming rules",
      "args": [
        "-c",
        "exec \"$HOME/.config/ai-mcp/bin/magic\""
      ],
      "command": "zsh",
      "env": {
        "TWENTYFIRST_API_KEY": ""
      },
      "type": "stdio"
    }
  },
  "agents": {
    "overrides": {}
  },
  "context": {
    "fileFiltering": {
      "enableRecursiveFileSearch": true,
      "respectGitIgnore": true
    }
  },
  "experimental": {},
  "general": {
    "checkpointing": {
      "enabled": true
    },
    "enableNotifications": true,
    "enablePromptCompletion": true,
    "plan": {
      "enabled": true
    },
    "previewFeatures": false,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "vimMode": true
  },
  "hooks": {
    "AfterAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/notification.sh --event after_agent"
          },
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py after_agent"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py before_agent"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py before_tool"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/notification.sh --event notification"
          },
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py notification"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py session_end"
          }
        ]
      }
    ]
  },
  "ide": {
    "enabled": true
  },
  "mcpServers": {
    "context7": {
      "args": [
        "-c",
        "exec \"$HOME/.config/ai-mcp/bin/context7\""
      ],
      "command": "zsh"
    },
    "gitmcp": {
      "args": [
        "-c",
        "exec \"$HOME/.config/ai-mcp/bin/gitmcp\" https://gitmcp.io/docs"
      ],
      "command": "zsh"
    },
    "morphllm-fast-apply": {
      "args": [
        "-c",
        "exec \"$HOME/.config/ai-mcp/bin/morphllm-fast-apply\""
      ],
      "command": "zsh",
      "env": {
        "ALL_TOOLS": "true",
        "MORPH_API_KEY": ""
      }
    },
    "playwright": {
      "args": [
        "-c",
        "exec \"$HOME/.config/ai-mcp/bin/playwright\""
      ],
      "command": "zsh"
    },
    "sequential-thinking": {
      "args": [
        "-c",
        "exec \"$HOME/.config/ai-mcp/bin/sequential-thinking\""
      ],
      "command": "zsh"
    },
    "serena": {
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "command": "/usr/local/bin/uvx"
    },
    "superagent": {
      "args": [
        "-c",
        "exec \"$HOME/.config/ai-mcp/bin/superagent\""
      ],
      "command": "zsh"
    }
  },
  "model": {
    "name": ""
  },
  "output": {
    "format": "text"
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true
  },
  "tools": {
    "autoAccept": false,
    "sandbox": false,
    "shell": {
      "showColor": true
    }
  },
  "ui": {
    "errorVerbosity": "full",
    "footer": {
      "hideContextPercentage": false,
      "hideSandboxStatus": true,
      "items": [
        "workspace",
        "git-branch",
        "model-name",
        "context-used",
        "quota",
        "token-count"
      ],
      "showLabels": true
    },
    "hideBanner": true,
    "hideTips": true,
    "inlineThinkingMode": "full",
    "loadingPhrases": "all",
    "showCitations": true,
    "showLineNumbers": true,
    "showMemoryUsage": true,
    "showModelInfoInChat": true,
    "showStatusInTitle": true,
    "theme": "Dracula",
    "useAlternateBuffer": false
  }
}
