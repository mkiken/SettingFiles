{
  "agents": {
    "overrides": {}
  },
  "context": {
    "fileFiltering": {
      "enableRecursiveFileSearch": true,
      "respectGitIgnore": true
    }
  },
  "experimental": {},
  "general": {
    "checkpointing": {
      "enabled": true
    },
    "enableNotifications": true,
    "enablePromptCompletion": true,
    "plan": {
      "enabled": true
    },
    "previewFeatures": false,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "vimMode": true
  },
  "hooks": {
    "AfterModel": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli aftermodel"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli aftertool"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/notification.sh --event after_agent"
          },
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py after_agent"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py before_agent"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "run_shell_command|read_file|read_many_files|grep_search|search_file_content|web_fetch|activate_skill|mcp__plugin_context-mode",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli beforetool"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py before_tool"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/hooks/notification.sh --event notification"
          },
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py notification"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli precompress"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli sessionstart"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/hooks/gemini-hook.py session_end"
          }
        ]
      }
    ]
  },
  "ide": {
    "enabled": true
  },
  "mcpServers": {
    "context-mode": {
      "command": "context-mode"
    }
  },
  "model": {
    "name": ""
  },
  "output": {
    "format": "text"
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true
  },
  "tools": {
    "autoAccept": false,
    "sandbox": false,
    "shell": {
      "showColor": true
    }
  },
  "ui": {
    "errorVerbosity": "full",
    "footer": {
      "hideContextPercentage": false,
      "hideSandboxStatus": true,
      "items": [
        "workspace",
        "git-branch",
        "model-name",
        "context-used",
        "quota",
        "token-count"
      ],
      "showLabels": true
    },
    "hideBanner": true,
    "hideTips": true,
    "inlineThinkingMode": "full",
    "loadingPhrases": "all",
    "showCitations": true,
    "showLineNumbers": true,
    "showMemoryUsage": true,
    "showModelInfoInChat": true,
    "showStatusInTitle": true,
    "theme": "Dracula",
    "useAlternateBuffer": false
  }
}
