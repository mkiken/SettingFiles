{
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true
  },
  "env": {
    "ENABLE_EXPERIMENTAL_MCP_CLI": "false",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/stop-send-notification.sh",
            "type": "command"
          },
          {
            "command": "afplay /System/Library/Sounds/Ping.aiff",
            "type": "command"
          },
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/stop-send-notification.sh",
            "type": "command"
          },
          {
            "command": "afplay /System/Library/Sounds/Ping.aiff",
            "type": "command"
          },
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "language": "japanese",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(base64:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(tail:*)",
      "LS",
      "Read",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo :*)",
      "NotebookEdit"
    ]
  },
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "type": "command"
  }
}
