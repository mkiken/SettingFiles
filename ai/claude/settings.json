{
  "enabledPlugins": {},
  "env": {
    "ENABLE_EXPERIMENTAL_MCP_CLI": "false",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/stop-send-notification.sh",
            "type": "command"
          },
          {
            "command": "afplay /System/Library/Sounds/Ping.aiff",
            "type": "command"
          },
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "workmux set-window-status waiting",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt|elicitation_dialog"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "workmux set-window-status working",
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/stop-send-notification.sh",
            "type": "command"
          },
          {
            "command": "afplay /System/Library/Sounds/Ping.aiff",
            "type": "command"
          },
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "workmux set-window-status done",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/claude-hook.py",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "workmux set-window-status working",
            "type": "command"
          }
        ]
      }
    ]
  },
  "language": "japanese",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Read",
      "LS",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /*)",
      "Bash(sudo :*)",
      "NotebookEdit"
    ]
  },
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "type": "command"
  }
}
