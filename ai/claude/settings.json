{
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "context-mode@context-mode": true,
    "dev-browser@dev-browser-marketplace": true,
    "superpowers@claude-plugins-official": true,
    "tsumiki@tsumiki": true
  },
  "env": {
    "ENABLE_EXPERIMENTAL_MCP_CLI": "false",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "dev-browser-marketplace": {
      "source": {
        "repo": "sawyerhood/dev-browser",
        "source": "github"
      }
    },
    "thedotmack": {
      "source": {
        "repo": "thedotmack/claude-mem",
        "source": "github"
      }
    },
    "tsumiki": {
      "source": {
        "source": "git",
        "url": "https://github.com/classmethod/tsumiki.git"
      }
    }
  },
  "fileSuggestion": {
    "command": "~/.claude/scripts/file-suggestion.sh",
    "type": "command"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-send-notification.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-hook.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-hook.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-send-notification.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-hook.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/claude-hook.py"
          }
        ]
      }
    ]
  },
  "language": "japanese",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(base64:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(tail:*)",
      "LS",
      "Read",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo :*)",
      "NotebookEdit"
    ]
  },
  "preferredNotifChannel": "ghostty",
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "padding": 0,
    "type": "command"
  },
  "verbose": true
}
