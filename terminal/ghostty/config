# Theme
theme = Mariana

# Font
font-family = Menlo
# 日本語用fallback
font-family = Hiragino Sans W4
font-feature = -dlig
font-size = 13

alpha-blending = linear

window-theme = ghostty
background-opacity = 0.85
background-blur-radius = 20

# コマンドが終了したら表示内容を確認しておきたい
wait-after-command = true

# メニューバーのタイトルを非表示にする
title = " "

# macOS
macos-window-shadow = false
macos-titlebar-style = transparent
# ネイティブの全画面は使いたくない
macos-non-native-fullscreen = true

# Window
window-padding-x = 3
window-padding-balance = true

# Shell
shell-integration-features = no-cursor

# Cursor
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true
cursor-opacity = 0.8

# Other
mouse-hide-while-typing = true
resize-overlay = never
# Shift+Enter / Alt+Enter で改行（codex CLI / Claude Code 共通、tmux内でも機能）
keybind = shift+enter=text:\n
keybind = alt+enter=text:\n

# Option+数字だけtmuxのMeta数字として送る
keybind = alt+digit_0=esc:0
keybind = alt+digit_1=esc:1
keybind = alt+digit_2=esc:2
keybind = alt+digit_3=esc:3
keybind = alt+digit_4=esc:4
keybind = alt+digit_5=esc:5
keybind = alt+digit_6=esc:6
keybind = alt+digit_7=esc:7
keybind = alt+digit_8=esc:8
keybind = alt+digit_9=esc:9
